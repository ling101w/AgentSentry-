{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "config.ts",
    "index.ts",
    "core/**/*.ts",
    "server/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.d.ts",
    "vitest.config.ts"
  ],
  "exclude": ["dist", "node_modules", "public/vendor"]
}
