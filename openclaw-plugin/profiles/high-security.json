{
  "profile": "high-security",
  "enforcement": { "mode": "block" },
  "semantic": {
    "enabled": true,
    "mode": "risk-tiered",
    "judgeToolCalls": true,
    "judgeMessages": false,
    "judgeMemoryWrites": true,
    "judgeProvenance": true
  },
  "policy": {
    "deterministic": true,
    "taintFeedback": true,
    "restrictWritesToAllowedRoots": true,
    "allowedWriteRoots": ["notes", "reports", "output", "src", "tests"]
  },
  "runtimeIsolation": { "requireKernelObserverForHighRisk": true, "unavailableAction": "block", "auditAfterExecution": true },
  "responseCover": { "enabled": true, "coverAssistantAfterContamination": true },
  "notifications": { "enableProactiveNotifications": true, "minSeverity": "warning" }
}
