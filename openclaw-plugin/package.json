{
  "name": "@openclaw/agent-sentry",
  "version": "0.2.0",
  "private": true,
  "description": "AgentSentry records and lightweight guard telemetry for OpenClaw",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 config.ts index.ts core server tests",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:fuzz": "vitest run tests/fuzz",
    "test:coverage": "vitest run --coverage",
    "test:policy": "npm run build && node ./scripts/policy-smoke.mjs && node ./scripts/agentdojo-policy-bridge.mjs --self-test",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage && npm run test:policy",
    "sbom": "node ./scripts/generate-sbom.mjs"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "fast-check": "^4.9.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
