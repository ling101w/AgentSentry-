# Python / local environments
.venv/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
*.pyc
*.pyo

# Node / frontend builds
node_modules/
dist/
build/
coverage/

# Local tools and browser automation state
.playwright-mcp/
.cache/
.tmp/
tmp/

# Secrets and local runtime state
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa*
id_ed25519*
*.db
*.sqlite
*.sqlite3
*.pid
*.log
*.jsonl
*.local.json
runtime/*
!runtime/README.md
runtime/agentdojo/
.openclaw/

# Evaluation fixtures are versioned; the real independent holdout stays sealed.
!evaluation/**/*.jsonl
evaluation/blind/blind_holdout*.jsonl
!evaluation/blind/blind_holdout.example.jsonl
evaluation/native/*.private.jsonl
evaluation/native/*.private.json

# OpenClaw local workspace may contain credentials and machine-local state.
openclaw-workspace/

# External research repos are large and not required for runtime deployment.
AgentWard-main/
AgentWard-main.zip
third_party/benchmarks/*
!third_party/benchmarks/README.md

# Generated frontend alternates kept out of source control.
src/agentsentry/static/security-screen.css
src/agentsentry/static/security-screen.js

# Generated reports and one-off artifacts.
reports/**/*.png
reports/**/*.docx
reports/benchmark_eval/
reports/tool_attack_benchmark/
reports/full_acceptance/full_acceptance_report_*.md
reports/full_acceptance/full_acceptance_results_*.json
reports/supervision_ablation/baseline-escaped-writes/
reports/supervision_ablation/*-outbox.jsonl
reports/supervision_ablation/*-shell-exec.jsonl
reports/supervision_ablation/*-memory.json
reports/supervision_ablation/*-sensitive-read.jsonl
reports/blind_evaluation/*.private.json
reports/native_agentdojo/*.private.*
openclaw-plugin/sbom.cdx.json

# Output keeps the README and compressed deliverables, not expanded build trees.
output/*
!output/README.md
!output/*.tar.gz
